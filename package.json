{
    "name": "csky-cdk-assistant",
    "displayName": "C-SKY CDK Assistant",
    "description": "C-SKY Development Kit (CDK) build support in VS Code using cdk-make.",
    "version": "0.0.3",
    "icon": "resources/cdk_logo.png",
    "publisher": "phantomfancy",
    "author": "phantomfancy",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/phantomfancy/csky-cdk-assistant.git"
    },
    "bugs": {
        "url": "https://github.com/phantomfancy/csky-cdk-assistant/issues"
    },
    "engines": {
        "vscode": "^1.125.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extensionMain.js",
    "contributes": {
        "commands": [
            {
                "command": "csky-cdk-assistant.configureCdkMake",
                "title": "%command.configureCdkMake%"
            },
            {
                "command": "csky-cdk-assistant.selectWorkspace",
                "title": "%command.selectWorkspace%"
            },
            {
                "command": "csky-cdk-assistant.selectProject",
                "title": "%command.selectProject%"
            },
            {
                "command": "csky-cdk-assistant.selectBuildSet",
                "title": "%command.selectBuildSet%"
            },
            {
                "command": "csky-cdk-assistant.build",
                "title": "%command.build%"
            },
            {
                "command": "csky-cdk-assistant.rebuild",
                "title": "%command.rebuild%"
            },
            {
                "command": "csky-cdk-assistant.clean",
                "title": "%command.clean%"
            },
            {
                "command": "csky-cdk-assistant.buildAll",
                "title": "%command.buildAll%"
            },
            {
                "command": "csky-cdk-assistant.refresh",
                "title": "%command.refresh%"
            },
            {
                "command": "csky-cdk-assistant.openConfiguration",
                "title": "%command.openConfiguration%"
            },
            {
                "command": "csky-cdk-assistant.doctor",
                "title": "%command.doctor%"
            },
            {
                "command": "csky-cdk-assistant.showHelp",
                "title": "%command.showHelp%"
            }
        ],
        "keybindings": [
            {
                "command": "csky-cdk-assistant.build",
                "key": "ctrl+f7",
                "when": "workspaceFolderCount > 0"
            },
            {
                "command": "csky-cdk-assistant.rebuild",
                "key": "ctrl+shift+f7",
                "when": "workspaceFolderCount > 0"
            },
            {
                "command": "csky-cdk-assistant.clean",
                "key": "alt+f7",
                "when": "workspaceFolderCount > 0"
            }
        ],
        "configuration": {
            "title": "C-SKY CDK Assistant",
            "properties": {
                "csky-cdk-assistant.cdkMakePath": {
                    "type": "string",
                    "default": "",
                    "scope": "machine",
                    "description": "Path to cdk-make.exe. The standard C-SKY CDK installation path is used when empty."
                }
            }
        },
        "taskDefinitions": [
            {
                "type": "csky-cdk",
                "required": [
                    "action"
                ],
                "properties": {
                    "action": {
                        "type": "string",
                        "enum": [
                            "build",
                            "rebuild",
                            "clean",
                            "doctor"
                        ]
                    },
                    "folder": {
                        "type": "string"
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "oxlint src",
        "test": "vscode-test"
    },
    "dependencies": {
        "fast-xml-parser": "^5.9.3"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "24.x",
        "@types/vscode": "^1.125.0",
        "@vscode/test-cli": "^0.0.15",
        "@vscode/test-electron": "^3.0.0",
        "oxlint": "^1.73.0",
        "typescript": "^7.0.2"
    },
    "overrides": {
        "diff": "^8.0.4",
        "serialize-javascript": "^7.0.6"
    }
}
